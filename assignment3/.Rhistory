modelsummary(
list("LPM Bivariate" = lpm1,
"LPM Controlled" = lpm2,
"Logit Bivariate" = logit1,
"Logit Controlled" = logit2),
vcov = c("HC1", "HC1", NULL, NULL),  # robust SE for LPMs only
stars = TRUE,
output = "gt")
vcov_list <- list(
"LPM Bivariate" = "HC1",
"LPM Controlled" = "HC1",
"Logit Bivariate" = "HC0",
